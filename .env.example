# Local development only. Do not use these credentials in production.
NODE_ENV=development

API_PORT=3002
DASHBOARD_PORT=3000
STOREFRONT_PORT=3001
DASHBOARD_ORIGIN=http://localhost:3000
STOREFRONT_ORIGIN=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
DEV_USER_EMAIL=owner@example.com
AUTH_ALLOW_DEV_IDENTITY=false
AUTH_EXPOSE_DEV_RESET_TOKEN=true
DEV_SEED_USER_PASSWORD=development123
AUTH_SESSION_COOKIE_NAME=mercurio_session
AUTH_SESSION_TTL_DAYS=30
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_APP_ORIGIN=http://localhost:3000
MEDIA_STORAGE_DIR=.local-media
MEDIA_PUBLIC_BASE_URL=http://localhost:3002

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=site_platform
POSTGRES_PASSWORD=site_platform_local_password
POSTGRES_DB=site_platform_dev
POSTGRES_TEST_DB=site_platform_test

DATABASE_URL=postgresql://site_platform:site_platform_local_password@localhost:5432/site_platform_dev?schema=public
TEST_DATABASE_URL=postgresql://site_platform:site_platform_local_password@localhost:5432/site_platform_test?schema=public

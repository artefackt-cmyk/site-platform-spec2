{
  "name": "site-platform-spec2",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:dashboard": "pnpm --filter @site-platform/dashboard dev",
    "dev:dashboard:clean": "pnpm --filter @site-platform/dashboard dev:clean",
    "dev:storefront": "pnpm --filter @site-platform/storefront dev",
    "dev:storefront:clean": "pnpm --filter @site-platform/storefront dev:clean",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @site-platform/database db:generate",
    "db:migrate": "pnpm --filter @site-platform/database db:migrate",
    "db:migrate:test": "pnpm --filter @site-platform/database db:migrate:test",
    "db:seed": "pnpm --filter @site-platform/database db:seed",
    "db:studio": "pnpm --filter @site-platform/database db:studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset:test": "pnpm --filter @site-platform/database db:reset:test"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.3.0",
    "eslint": "^9.35.0",
    "tsx": "^4.20.5",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.2.4"
  }
}

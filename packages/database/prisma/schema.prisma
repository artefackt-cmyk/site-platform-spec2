generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  EDITOR
  STORE_MANAGER
  VIEWER
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SitePageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  displayName String?      @map("display_name")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  memberships Membership[]
  auditLogs   AuditLog[]   @relation("AuditActor")

  @@map("users")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  memberships Membership[]
  projects    Project[]
  sitePages   SitePage[]
  pageDocuments PageDocument[]
  auditLogs   AuditLog[]

  @@map("organizations")
}

model Membership {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  organizationId String           @map("organization_id")
  role           OrganizationRole
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  user           User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model Project {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  name           String
  slug           String
  status         ProjectStatus @default(DRAFT)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sitePages      SitePage[]
  pageDocuments  PageDocument[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("projects")
}

model SitePage {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  projectId      String         @map("project_id")
  title          String
  slug           String
  status         SitePageStatus @default(DRAFT)
  isHome         Boolean        @default(false) @map("is_home")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  pageDocument   PageDocument?

  @@unique([projectId, slug])
  @@index([organizationId, projectId])
  @@index([projectId])
  @@map("site_pages")
}

model PageDocument {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  projectId      String       @map("project_id")
  pageId         String       @unique @map("page_id")
  schemaVersion  Int          @map("schema_version")
  document       Json
  revision       Int          @default(1)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  page           SitePage     @relation(fields: [pageId], references: [id], onDelete: Restrict)

  @@index([organizationId, projectId, pageId])
  @@map("page_documents")
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  actorUserId    String?      @map("actor_user_id")
  action         String
  entityType     String       @map("entity_type")
  entityId       String?      @map("entity_id")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  actorUser      User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  EDITOR
  STORE_MANAGER
  VIEWER
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SiteStatus {
  ACTIVE
  ARCHIVED
}

enum SitePageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductCurrency {
  RUB
}

enum OrderStatus {
  NEW
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  displayName String?      @map("display_name")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  memberships Membership[]
  authSessions AuthSession[]
  passwordCredential PasswordCredential?
  passwordResetTokens PasswordResetToken[]
  auditLogs   AuditLog[]   @relation("AuditActor")
  mediaAssets MediaAsset[] @relation("MediaAssetCreator")
  publishedSnapshots PublishedPageSnapshot[] @relation("PublishedByUser")
  createdProducts Product[] @relation("ProductCreator")
  updatedProducts Product[] @relation("ProductUpdater")

  @@map("users")
}

model AuthSession {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  lastSeenAt DateTime  @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("auth_sessions")
}

model PasswordCredential {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  passwordHash      String   @map("password_hash")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  passwordChangedAt DateTime @default(now()) @map("password_changed_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  memberships Membership[]
  projects    Project[]
  sites       Site[]
  sitePages   SitePage[]
  pageDocuments PageDocument[]
  mediaAssets MediaAsset[]
  products Product[]
  productVariants ProductVariant[]
  productMedia ProductMedia[]
  orders Order[]
  orderItems OrderItem[]
  projectOrderCounters ProjectOrderCounter[]
  publicationSettings ProjectPublicationSettings[]
  projectSiteSettings ProjectSiteSettings[]
  publishedPageSnapshots PublishedPageSnapshot[]
  publishedPageStates PublishedPageState[]
  auditLogs   AuditLog[]

  @@map("organizations")
}

model Membership {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  organizationId String           @map("organization_id")
  role           OrganizationRole
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  user           User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model Project {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  name           String
  slug           String
  status         ProjectStatus @default(DRAFT)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sites          Site[]
  sitePages      SitePage[]
  pageDocuments  PageDocument[]
  mediaAssets    MediaAsset[]
  products       Product[]
  productVariants ProductVariant[]
  productMedia    ProductMedia[]
  orders          Order[]
  orderItems      OrderItem[]
  orderCounter    ProjectOrderCounter?
  publicationSettings ProjectPublicationSettings[]
  siteSettings ProjectSiteSettings[]
  publishedPageSnapshots PublishedPageSnapshot[]
  publishedPageStates PublishedPageState[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("projects")
}

model Site {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  projectId      String       @map("project_id")
  name           String
  slug           String
  status         SiteStatus   @default(ACTIVE)
  isDefault      Boolean      @default(false) @map("is_default")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  pages          SitePage[]
  pageDocuments  PageDocument[]
  publicationSettings ProjectPublicationSettings?
  siteSettings ProjectSiteSettings?
  publishedPageSnapshots PublishedPageSnapshot[]
  publishedPageStates PublishedPageState[]

  @@unique([projectId, slug])
  @@index([organizationId])
  @@index([projectId])
  @@index([projectId, status])
  @@map("sites")
}

model SitePage {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  projectId      String         @map("project_id")
  siteId         String         @map("site_id")
  title          String
  slug           String
  status         SitePageStatus @default(DRAFT)
  isHome         Boolean        @default(false) @map("is_home")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  site           Site           @relation(fields: [siteId], references: [id], onDelete: Restrict)
  pageDocument   PageDocument?
  publishedSnapshots PublishedPageSnapshot[]
  publishedState PublishedPageState?

  @@unique([siteId, slug])
  @@index([organizationId, projectId, siteId])
  @@index([projectId])
  @@index([siteId])
  @@map("site_pages")
}

model ProjectPublicationSettings {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  projectId      String       @map("project_id")
  siteId         String       @unique @map("site_id")
  publicHandle   String       @unique @map("public_handle")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  site           Site         @relation(fields: [siteId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([projectId])
  @@map("project_publication_settings")
}

model ProjectSiteSettings {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  projectId      String       @map("project_id")
  siteId         String       @unique @map("site_id")
  headerDraft    Json         @map("header_draft")
  footerDraft    Json         @map("footer_draft")
  headerEnabled  Boolean      @default(true) @map("header_enabled")
  footerEnabled  Boolean      @default(true) @map("footer_enabled")
  revision       Int          @default(1)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  site           Site         @relation(fields: [siteId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([projectId])
  @@map("project_site_settings")
}

model PublishedPageSnapshot {
  id                       String       @id @default(cuid())
  organizationId           String       @map("organization_id")
  projectId                String       @map("project_id")
  siteId                   String       @map("site_id")
  pageId                   String       @map("page_id")
  version                  Int
  pageTitle                String       @map("page_title")
  pageSlug                 String       @map("page_slug")
  documentJson             Json         @map("document_json")
  siteSettingsJson         Json?        @map("site_settings_json")
  sourceRevision           Int          @map("source_revision")
  rollbackSourceSnapshotId String?      @map("rollback_source_snapshot_id")
  publishedByUserId        String       @map("published_by_user_id")
  publishedAt              DateTime     @default(now()) @map("published_at")
  createdAt                DateTime     @default(now()) @map("created_at")
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project                  Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  site                     Site         @relation(fields: [siteId], references: [id], onDelete: Restrict)
  page                     SitePage     @relation(fields: [pageId], references: [id], onDelete: Restrict)
  publishedByUser          User         @relation("PublishedByUser", fields: [publishedByUserId], references: [id], onDelete: Restrict)
  activeStates             PublishedPageState[] @relation("ActivePublishedSnapshot")

  @@unique([pageId, version])
  @@index([organizationId])
  @@index([projectId])
  @@index([siteId])
  @@index([pageId])
  @@index([siteId, pageSlug])
  @@index([publishedAt])
  @@map("published_page_snapshots")
}

model PublishedPageState {
  id               String                 @id @default(cuid())
  organizationId   String                 @map("organization_id")
  projectId        String                 @map("project_id")
  siteId           String                 @map("site_id")
  pageId           String                 @unique @map("page_id")
  activeSnapshotId String?                @map("active_snapshot_id")
  publishedAt      DateTime?              @map("published_at")
  unpublishedAt    DateTime?              @map("unpublished_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project          Project                @relation(fields: [projectId], references: [id], onDelete: Restrict)
  site             Site                   @relation(fields: [siteId], references: [id], onDelete: Restrict)
  page             SitePage               @relation(fields: [pageId], references: [id], onDelete: Restrict)
  activeSnapshot   PublishedPageSnapshot? @relation("ActivePublishedSnapshot", fields: [activeSnapshotId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([projectId])
  @@index([siteId])
  @@index([activeSnapshotId])
  @@map("published_page_states")
}

model PageDocument {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  projectId      String       @map("project_id")
  siteId         String       @map("site_id")
  pageId         String       @unique @map("page_id")
  schemaVersion  Int          @map("schema_version")
  document       Json
  revision       Int          @default(1)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  site           Site         @relation(fields: [siteId], references: [id], onDelete: Restrict)
  page           SitePage     @relation(fields: [pageId], references: [id], onDelete: Restrict)

  @@index([organizationId, projectId, siteId, pageId])
  @@map("page_documents")
}

model MediaAsset {
  id               String       @id @default(cuid())
  organizationId   String       @map("organization_id")
  projectId        String       @map("project_id")
  storageKey       String       @unique @map("storage_key")
  originalFilename String       @map("original_filename")
  mimeType         String       @map("mime_type")
  sizeBytes        Int          @map("size_bytes")
  width            Int?
  height           Int?
  altText          String?      @map("alt_text")
  createdByUserId  String       @map("created_by_user_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  createdByUser    User         @relation("MediaAssetCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  primaryForProducts Product[]
  productMedia      ProductMedia[]

  @@index([organizationId])
  @@index([projectId])
  @@index([projectId, createdAt])
  @@map("media_assets")
}

model Product {
  id                  String           @id @default(cuid())
  organizationId      String           @map("organization_id")
  projectId           String           @map("project_id")
  title               String
  slug                String
  shortDescription    String?          @map("short_description")
  description         String?
  status              ProductStatus    @default(DRAFT)
  primaryMediaAssetId String?          @map("primary_media_asset_id")
  createdByUserId     String           @map("created_by_user_id")
  updatedByUserId     String           @map("updated_by_user_id")
  externalId          String?          @map("external_id")
  externalSource      String?          @map("external_source")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  deletedAt           DateTime?        @map("deleted_at")
  organization        Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project             Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  primaryMediaAsset   MediaAsset?      @relation(fields: [primaryMediaAssetId], references: [id], onDelete: Restrict)
  createdByUser       User             @relation("ProductCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser       User             @relation("ProductUpdater", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  variants            ProductVariant[]
  media               ProductMedia[]
  orderItems          OrderItem[]

  @@unique([projectId, slug])
  @@index([organizationId])
  @@index([projectId])
  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([primaryMediaAssetId])
  @@map("products")
}

model ProductVariant {
  id                  String          @id @default(cuid())
  organizationId      String          @map("organization_id")
  projectId           String          @map("project_id")
  productId           String          @map("product_id")
  title               String
  sku                 String
  priceMinor          Int             @map("price_minor")
  compareAtPriceMinor Int?            @map("compare_at_price_minor")
  currency            ProductCurrency @default(RUB)
  stockQuantity       Int             @default(0) @map("stock_quantity")
  trackInventory      Boolean         @default(true) @map("track_inventory")
  allowBackorder      Boolean         @default(false) @map("allow_backorder")
  isDefault           Boolean         @default(false) @map("is_default")
  position            Int             @default(0)
  externalId          String?         @map("external_id")
  externalSource      String?         @map("external_source")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  deletedAt           DateTime?       @map("deleted_at")
  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Restrict)
  product             Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  orderItems          OrderItem[]

  @@unique([projectId, sku])
  @@index([organizationId])
  @@index([projectId])
  @@index([productId])
  @@index([productId, isDefault])
  @@index([productId, position])
  @@map("product_variants")
}

model ProjectOrderCounter {
  id              String       @id @default(cuid())
  organizationId  String       @map("organization_id")
  projectId       String       @unique @map("project_id")
  lastOrderNumber Int          @default(1000) @map("last_order_number")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@map("project_order_counters")
}

model Order {
  id                     String       @id @default(cuid())
  organizationId         String       @map("organization_id")
  projectId              String       @map("project_id")
  orderNumber            Int          @map("order_number")
  status                 OrderStatus  @default(NEW)
  currency               ProductCurrency @default(RUB)
  subtotalMinor          Int          @map("subtotal_minor")
  totalMinor             Int          @map("total_minor")
  customerName           String       @map("customer_name")
  customerEmail          String       @map("customer_email")
  customerPhone          String?      @map("customer_phone")
  customerComment        String?      @map("customer_comment")
  idempotencyKey         String       @map("idempotency_key")
  idempotencyPayloadHash String       @map("idempotency_payload_hash")
  publicHandleSnapshot   String       @map("public_handle_snapshot")
  publicTokenHash        String       @unique @map("public_token_hash")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")
  cancelledAt            DateTime?    @map("cancelled_at")
  completedAt            DateTime?    @map("completed_at")
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project                Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  items                  OrderItem[]

  @@unique([projectId, orderNumber])
  @@unique([projectId, idempotencyKey])
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
  @@map("orders")
}

model OrderItem {
  id                    String          @id @default(cuid())
  orderId               String          @map("order_id")
  organizationId        String          @map("organization_id")
  projectId             String          @map("project_id")
  productId             String?         @map("product_id")
  variantId             String?         @map("variant_id")
  productNameSnapshot   String          @map("product_name_snapshot")
  variantNameSnapshot   String          @map("variant_name_snapshot")
  skuSnapshot           String          @map("sku_snapshot")
  unitPriceMinor        Int             @map("unit_price_minor")
  quantity              Int
  lineTotalMinor        Int             @map("line_total_minor")
  currency              ProductCurrency @default(RUB)
  mediaUrlSnapshot      String?         @map("media_url_snapshot")
  inventoryDecremented  Boolean         @default(false) @map("inventory_decremented")
  createdAt             DateTime        @default(now()) @map("created_at")
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project               Project         @relation(fields: [projectId], references: [id], onDelete: Restrict)
  product               Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant               ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model ProductMedia {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  projectId      String       @map("project_id")
  productId      String       @map("product_id")
  mediaAssetId   String       @map("media_asset_id")
  position       Int
  isPrimary      Boolean      @default(false) @map("is_primary")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  mediaAsset     MediaAsset   @relation(fields: [mediaAssetId], references: [id], onDelete: Restrict)

  @@unique([productId, mediaAssetId])
  @@index([organizationId])
  @@index([projectId])
  @@index([productId])
  @@index([productId, position])
  @@map("product_media")
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  actorUserId    String?      @map("actor_user_id")
  action         String
  entityType     String       @map("entity_type")
  entityId       String?      @map("entity_id")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  actorUser      User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}

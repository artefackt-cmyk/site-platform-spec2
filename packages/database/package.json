{
  "name": "@site-platform/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.json",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "tsx src/scripts/migrate-database.ts",
    "db:migrate:test": "tsx src/scripts/migrate-test-database.ts",
    "db:reset:test": "tsx src/scripts/reset-test-database.ts",
    "db:seed": "tsx src/scripts/seed-development.ts",
    "db:studio": "tsx src/scripts/open-studio.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "pnpm db:generate && tsc --noEmit -p tsconfig.json",
    "test": "pnpm db:generate && vitest run --passWithNoTests"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@site-platform/config": "workspace:*",
    "@site-platform/domain": "workspace:*",
    "@site-platform/editor-core": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^6.19.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false
}
